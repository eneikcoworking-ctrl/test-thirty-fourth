{
  "openapi": "3.0.0",
  "info": {
    "title": "CRM Live Chat & AI Override API Contract",
    "description": "Unified inbox, real-time messaging, and AI override contract for the CRM Live Chat system (LeadGen Bot). This document acts as the single source of truth for the Svelte SvelteKit frontend and Java Spring Boot backend.\n\n### Real-time Messaging (WebSocket/SSE) Contract\nTo ensure real-time messaging synchronization, a WebSocket server is established at `/ws/inbox`. Clients should authenticate via query param `?token=JWT_TOKEN` or cookies.\n\n#### Outbound Events (Server to Client)\n- `message_received`: Triggered when a new message arrives from a contact.\n- `message_sent_success`: Confirmation that an operator message has been successfully broadcast to Telegram.\n- `thread_status_changed`: Fired when a thread's override state shifts (e.g. `ai_assistant` -> `human_attention`).\n- `typing_status`: Emitted when the contact or AI agent is simulated typing.\n\nAll real-time payloads inherit from the `WebSocketEvent` schema outlined in the components below.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/api/v1/inbox/threads": {
      "get": {
        "summary": "Retrieve Chat Threads",
        "description": "Returns a paginated list of chat threads, representing conversations with Telegram contacts. Supports filtering by handler status and tags.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter threads by handler status.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "human_attention",
                "ai_assistant",
                "pending"
              ]
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Filter threads by context tags.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "subscription_issue",
                "sales_inquiry",
                "technical_support",
                "new_lead",
                "critical_incident"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Fuzzy search by contact name, username, phone, or message content.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records to return.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved list of chat threads.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "threads",
                    "totalCount"
                  ],
                  "properties": {
                    "threads": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Thread"
                      }
                    },
                    "totalCount": {
                      "type": "integer",
                      "example": 1284
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/inbox/threads/{threadId}/messages": {
      "get": {
        "summary": "Retrieve Message History",
        "description": "Fetches a paginated history of messages in a specific thread.",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "before",
            "in": "query",
            "description": "Cursor for pagination. Retrieve messages older than this message ID.",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved message history.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "messages"
                  ],
                  "properties": {
                    "messages": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Message"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Thread not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Send Operator Message",
        "description": "Allows a human operator to send a manual message to the Telegram user. Sending a message via this endpoint must automatically pause the AI Assistant and transition the thread to 'human_attention' status.",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The plaintext message body to deliver.",
                    "example": "Hi Marcus, I see your request and I am reviewing your account right now."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message successfully queued for delivery and saved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., empty text body).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Thread not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/inbox/threads/{threadId}/override": {
      "post": {
        "summary": "Override AI Assistant Handler Mode",
        "description": "Explicitly switches the handling mode of a thread between the automated LLM Dialog Engine and manual Human operator attention.",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiOverrideRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI override mode successfully updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiOverrideResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., invalid mode specified).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Thread not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts": {
      "get": {
        "summary": "Retrieve Telegram Accounts",
        "description": "Returns a paginated list of managed Telegram accounts. Supports filtering by state status.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter accounts by status.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ACTIVE",
                "SPAM_BLOCK_TEMP",
                "BANNED",
                "REAUTH_REQUIRED"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records to return.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved list of Telegram accounts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/{accountId}": {
      "get": {
        "summary": "Retrieve Account Details",
        "description": "Fetches details and real-time status of a specific Telegram account by ID.",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved account details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TgAccount"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update Account Configuration",
        "description": "Updates proxy assignment and daily limits for a specific Telegram account.",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account successfully updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TgAccount"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., invalid proxy or limits).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account or proxy not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Telegram Account",
        "description": "Gracefully logs out (where possible) and removes a Telegram session and its credentials from the database.",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Account successfully disconnected and deleted."
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/otp/request": {
      "post": {
        "summary": "Request OTP Verification Code",
        "description": "Initiates authorization for a Telegram session by requesting an OTP code sent to the given phone number.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP successfully requested and sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., invalid phone format).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/otp/submit": {
      "post": {
        "summary": "Submit OTP and Complete Login",
        "description": "Completes login process for a Telegram session by submitting the received OTP and optional 2FA password.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpSubmitRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "OTP successfully verified and Telegram account created/logged in.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TgAccount"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., expired or incorrect OTP).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/import": {
      "post": {
        "summary": "Import Ready-to-Use Sessions",
        "description": "Allows direct upload of active sessions in .session/tdata JSON/Session format with proxy attachment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountImportRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sessions successfully imported.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TgAccount"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., malformed session payload).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict (e.g., phone number or session duplicate).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Contact": {
        "type": "object",
        "required": [
          "id",
          "name",
          "telegramUsername"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "d09228fb-28c0-43ef-bc43-2313bfa7e462"
          },
          "name": {
            "type": "string",
            "example": "Marcus Sterling"
          },
          "telegramUsername": {
            "type": "string",
            "example": "marcus_sterling_exec"
          },
          "phoneNumber": {
            "type": "string",
            "example": "+15550199281"
          },
          "avatarUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://lh3.googleusercontent.com/aida-public/AB6AXuAlSZeJHNBqrtNxIbIiH4PG4khiblq1HeBOovztiyEB-HhRiQCBIpIa5nLzWTUBjsco_PWmBjn3EIAuD7oH_pome4AnuiC3bCcUPsEN3UNqe8mVTx5Xj_Lc-qzz4lnp6MTgW2K956DAWARORKdjj6NxflEeWCIjUJOP-dfrFnod8XsXB_C1O_nXEn6tMIZ-pvXzuS5005HUwpiivMIwZTMUVCPxo9YHKyAXM8_mfpvkDp68FZk0zO400hi8k1RtxTBx6wVnXnMo_4M"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:00:00Z"
          }
        }
      },
      "Thread": {
        "type": "object",
        "required": [
          "id",
          "contact",
          "status",
          "unreadCount",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "3b290dfc-859a-4c22-b25c-897c55dae002"
          },
          "contact": {
            "$ref": "#/components/schemas/Contact"
          },
          "status": {
            "type": "string",
            "enum": [
              "human_attention",
              "ai_assistant",
              "pending"
            ],
            "example": "human_attention",
            "description": "Identifies who or what is currently controlling/responding within the thread."
          },
          "tag": {
            "type": "string",
            "enum": [
              "subscription_issue",
              "sales_inquiry",
              "technical_support",
              "new_lead",
              "critical_incident"
            ],
            "example": "subscription_issue"
          },
          "unreadCount": {
            "type": "integer",
            "example": 3
          },
          "lastMessage": {
            "$ref": "#/components/schemas/Message"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:05:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:13:21Z"
          }
        }
      },
      "Message": {
        "type": "object",
        "required": [
          "id",
          "threadId",
          "senderType",
          "text",
          "timestamp"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "f003e8cb-7e2a-466d-88b1-3e47e8f52219"
          },
          "threadId": {
            "type": "string",
            "format": "uuid",
            "example": "3b290dfc-859a-4c22-b25c-897c55dae002"
          },
          "senderType": {
            "type": "string",
            "enum": [
              "contact",
              "human_operator",
              "ai_assistant"
            ],
            "example": "contact"
          },
          "senderName": {
            "type": "string",
            "example": "Marcus Sterling",
            "description": "Name of the sender (either the contact name, operator name, or AI Agent's name)."
          },
          "text": {
            "type": "string",
            "example": "This is unacceptable, I need a refund immediately or I'm calling..."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:13:21Z"
          }
        }
      },
      "AiOverrideRequest": {
        "type": "object",
        "required": [
          "handlerMode"
        ],
        "properties": {
          "handlerMode": {
            "type": "string",
            "enum": [
              "human_attention",
              "ai_assistant",
              "pending"
            ],
            "example": "ai_assistant",
            "description": "The target handler status to enforce for the chat thread."
          },
          "overrideReason": {
            "type": "string",
            "example": "Enabling AI automated reply because the customer question is general pricing."
          }
        }
      },
      "AiOverrideResponse": {
        "type": "object",
        "required": [
          "threadId",
          "previousStatus",
          "currentStatus",
          "updatedAt"
        ],
        "properties": {
          "threadId": {
            "type": "string",
            "format": "uuid",
            "example": "3b290dfc-859a-4c22-b25c-897c55dae002"
          },
          "previousStatus": {
            "type": "string",
            "enum": [
              "human_attention",
              "ai_assistant",
              "pending"
            ],
            "example": "human_attention"
          },
          "currentStatus": {
            "type": "string",
            "enum": [
              "human_attention",
              "ai_assistant",
              "pending"
            ],
            "example": "ai_assistant"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:15:00Z"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "errorCode",
          "message",
          "timestamp"
        ],
        "properties": {
          "errorCode": {
            "type": "string",
            "example": "RESOURCE_NOT_FOUND",
            "description": "High-level machine-readable error classification."
          },
          "message": {
            "type": "string",
            "example": "Thread with UUID 3b290dfc-859a-4c22-b25c-897c55dae002 was not found."
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Thread look-up failed in database."
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:16:42Z"
          }
        }
      },
      "WebSocketEvent": {
        "type": "object",
        "required": [
          "event",
          "timestamp",
          "payload"
        ],
        "properties": {
          "event": {
            "type": "string",
            "enum": [
              "message_received",
              "message_sent_success",
              "thread_status_changed",
              "typing_status"
            ],
            "example": "message_received"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:13:22Z"
          },
          "payload": {
            "type": "object",
            "description": "Detailed body matching the event type.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/Message"
              },
              {
                "$ref": "#/components/schemas/AiOverrideResponse"
              },
              {
                "type": "object",
                "required": [
                  "threadId",
                  "isTyping"
                ],
                "properties": {
                  "threadId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "isTyping": {
                    "type": "boolean"
                  }
                }
              }
            ]
          }
        }
      },
      "Proxy": {
        "type": "object",
        "required": [
          "id",
          "host",
          "port",
          "protocol"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 42
          },
          "host": {
            "type": "string",
            "example": "192.168.1.100"
          },
          "port": {
            "type": "integer",
            "example": 1080
          },
          "protocol": {
            "type": "string",
            "enum": [
              "SOCKS5",
              "HTTP"
            ],
            "example": "SOCKS5"
          },
          "username": {
            "type": "string",
            "example": "proxy_user"
          },
          "password": {
            "type": "string",
            "example": "proxy_password"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:00:00Z"
          }
        }
      },
      "TgAccount": {
        "type": "object",
        "required": [
          "id",
          "userId",
          "phoneNumber",
          "status",
          "dailyDialogueLimit",
          "currentDailyDialoguesCount"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "example": 10
          },
          "proxy": {
            "$ref": "#/components/schemas/Proxy"
          },
          "phoneNumber": {
            "type": "string",
            "example": "+15550199281"
          },
          "username": {
            "type": "string",
            "example": "marcus_sterling"
          },
          "sessionFormat": {
            "type": "string",
            "enum": [
              "SESSION",
              "TDATA"
            ],
            "example": "SESSION"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SPAM_BLOCK_TEMP",
              "BANNED",
              "REAUTH_REQUIRED"
            ],
            "example": "ACTIVE",
            "description": "Current status/state of the Telegram account."
          },
          "dailyDialogueLimit": {
            "type": "integer",
            "example": 15,
            "description": "Hard limit on the number of new daily dialogues to avoid spam blocking."
          },
          "currentDailyDialoguesCount": {
            "type": "integer",
            "example": 4,
            "description": "Number of dialogues initiated on this account today."
          },
          "lastSyncAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-07-22T18:05:00Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-22T18:13:21Z"
          }
        }
      },
      "OtpRequest": {
        "type": "object",
        "required": [
          "phoneNumber"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "example": "+15550199281"
          },
          "proxyId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 42
          }
        }
      },
      "OtpRequestResponse": {
        "type": "object",
        "required": [
          "otpSessionId"
        ],
        "properties": {
          "otpSessionId": {
            "type": "string",
            "format": "uuid",
            "example": "a87fd62e-3601-4be6-a4c3-1ef96b34a123",
            "description": "UUID referencing this authorization flow/session."
          },
          "phoneNumber": {
            "type": "string",
            "example": "+15550199281"
          },
          "status": {
            "type": "string",
            "example": "SENT_OTP"
          }
        }
      },
      "OtpSubmitRequest": {
        "type": "object",
        "required": [
          "otpSessionId",
          "code"
        ],
        "properties": {
          "otpSessionId": {
            "type": "string",
            "format": "uuid",
            "example": "a87fd62e-3601-4be6-a4c3-1ef96b34a123"
          },
          "code": {
            "type": "string",
            "example": "12345",
            "description": "The OTP code sent via Telegram or SMS."
          },
          "password": {
            "type": "string",
            "example": "my_two_factor_password",
            "description": "Optional 2FA password/cloud password if configured for the account."
          }
        }
      },
      "AccountImportRequest": {
        "type": "object",
        "required": [
          "phoneNumber",
          "sessionFormat",
          "sessionData"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "example": "+15550199281"
          },
          "sessionFormat": {
            "type": "string",
            "enum": [
              "SESSION",
              "TDATA"
            ],
            "example": "SESSION"
          },
          "sessionData": {
            "type": "string",
            "example": "base64_or_hex_or_json_string_of_session",
            "description": "Serialized tdata/session payload"
          },
          "proxyId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 42
          },
          "dailyDialogueLimit": {
            "type": "integer",
            "example": 15
          }
        }
      },
      "AccountUpdateRequest": {
        "type": "object",
        "properties": {
          "proxyId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 42
          },
          "dailyDialogueLimit": {
            "type": "integer",
            "example": 20
          }
        }
      },
      "AccountListResponse": {
        "type": "object",
        "required": [
          "accounts",
          "totalCount"
        ],
        "properties": {
          "accounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TgAccount"
            }
          },
          "totalCount": {
            "type": "integer",
            "example": 5
          }
        }
      }
    }
  }
}